# ============================================================
# LLM 配置
# ============================================================

# 提供商: openai / anthropic / azure / custom
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Azure OpenAI
AZURE_API_KEY=
AZURE_ENDPOINT=
AZURE_DEPLOYMENT_NAME=

# 自定义（兼容 OpenAI 接口的服务，如 DeepSeek、Moonshot、智谱等）
CUSTOM_API_KEY=
CUSTOM_BASE_URL=
CUSTOM_MODEL=

# ============================================================
# 服务配置
# ============================================================

HOST=127.0.0.1
PORT=3000
# 可选：自定义 Web 设置页配置文件位置
# SCOUT_CONFIG_PATH=/absolute/path/to/config.json
PI_PATH=pi
