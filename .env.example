# input: 本机或部署环境变量
# output: Scout Web 模型、GitLab 发布和服务运行配置
# position: 环境变量模板，复制为 .env 后生效

# ============================================================
# LLM 配置
# ============================================================

# 提供商: openai / anthropic / azure / custom
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Azure OpenAI
AZURE_API_KEY=
AZURE_ENDPOINT=
AZURE_DEPLOYMENT_NAME=

# 自定义（兼容 OpenAI 接口的服务，如 DeepSeek、Moonshot、智谱等）
CUSTOM_API_KEY=
CUSTOM_BASE_URL=
CUSTOM_MODEL=

# ============================================================
# GitLab 发布配置
# ============================================================

GITLAB_BASE_URL=http://gitlab.data-match.net:8929
GITLAB_PROJECT_PATH=supply-chain/dm-supply-next
GITLAB_BRANCH=main
GITLAB_TOKEN=
GITLAB_SCRIPT_PACKAGE_PATH=tests/scout/scripts/scout-script-package.json
GITLAB_SUITE_PATH=tests/scout/suites/smoke.json

# ============================================================
# 服务配置
# ============================================================

HOST=127.0.0.1
PORT=3000
HOST=0.0.0.0
# 可选：自定义 Web 设置页配置文件位置
# SCOUT_CONFIG_PATH=/absolute/path/to/config.json
PI_PATH=pi
